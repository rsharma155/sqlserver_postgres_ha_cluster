# Copy this file to .env and fill in secure values before starting.
# NEVER commit .env to version control — it is listed in .gitignore.

# SQL Server SA password (must meet SQL Server complexity requirements:
#   min 8 chars, upper+lower+digit+special)
MSSQL_SA_PASSWORD=your_strong_sa_password_here

# Database master key password (used to encrypt certificates)
MASTER_KEY_PASSWORD=your_strong_master_key_password_here

# Certificate private-key encryption password
CERT_PASSWORD=your_strong_cert_password_here

# Monitoring/read-only user password (used by sqlserver_init.sql)
DBMONITOR_PASSWORD=Hello@123

# Node IDs (do not change unless restructuring the cluster)
SQL1_NODE_ID=1
SQL2_NODE_ID=2
SQL3_NODE_ID=3
